{
  "name": "iglidhima-arcade",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-page static browser-based arcade hub served at iglidhima.com",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@playwright/test": "^1.61.1",
    "fast-check": "^4.9.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.4.5",
    "vite": "^6.0.0",
    "vitest": "^2.1.8",
    "wrangler": "^4.0.0"
  }
}
